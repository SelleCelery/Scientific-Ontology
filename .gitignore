# .gitignore for VScode and Visual Studio projects
# Ignore everything by default
*

# Allow directories to be traversed
!*/

# Allow repository control files
!.gitignore
!README.md
!LICENSE.md
!ROADMAP.md
!GLOSSARY.md

# Allow public folders and selected public files
!00_Overview/**
!01_Sat_Truth/**
!02_Raj_Beauty/**
!03_Tam_Goodness/**
!99_Private_Core_Not_Included/**

# Python / local environment
.venv/
__pycache__/
*.py[cod]

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE local files
.vscode/
.vs/

# Temporary / backup files
*.log
*.tmp
*.bak
*.orig
*~

# Office temporary files
~$*.*

# Build outputs for docs
_build/
